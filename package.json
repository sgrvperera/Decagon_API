{
  "name": "playwright-api-framework",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npx playwright test tests/e2e/",
    "test:e2e": "npx playwright test tests/e2e/",
    "test:gsm": "npx playwright test tests/e2e/gsm-packages.spec.ts",
    "test:hbb": "npx playwright test tests/e2e/hbb-packages.spec.ts",
    "test:smoke": "npx playwright test tests/e2e/ --grep @smoke",
    "test:regression": "npx playwright test tests/e2e/ --grep @regression",
    "test:negative": "npx playwright test tests/e2e/ --grep @negative",
    "test:postpaid": "npx playwright test tests/e2e/ --grep @postpaid",
    "test:prepaid": "npx playwright test tests/e2e/ --grep @prepaid",
    "clean": "if exist .playwright-cache rmdir /s /q .playwright-cache && if exist test-results rmdir /s /q test-results",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "ajv": "^8.18.0",
    "dotenv": "^16.0.0",
    "eslint": "^8.0.0",
    "prettier": "^2.8.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "ajv-formats": "^3.0.1"
  }
}
