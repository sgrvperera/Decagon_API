{
  "name": "playwright-api-framework",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npx playwright test tests/e2e/",
    "test:e2e": "npx playwright test tests/e2e/",
    "test:gsm": "npx playwright test tests/e2e/gsm-packages.spec.ts",
    "test:hbb": "npx playwright test tests/e2e/hbb-packages.spec.ts",
    "test:smoke": "TEST_TAG=@smoke npx playwright test tests/e2e/",
    "test:regression": "TEST_TAG=@regression npx playwright test tests/e2e/",
    "test:negative": "TEST_TAG=@negative npx playwright test tests/e2e/",
    "test:mock": "MOCK_API=true npx playwright test tests/e2e/",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "ajv": "^8.12.0",
    "dotenv": "^16.0.0",
    "eslint": "^8.0.0",
    "prettier": "^2.8.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "xlsx": "^0.18.5"
  }
}
